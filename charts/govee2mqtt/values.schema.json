{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "global": {
      "type": "object"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of replicas to deploy"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Docker image repository"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "description": "Image pull policy"
        },
        "tag": {
          "type": "string",
          "description": "Docker image tag, defaults to chart appVersion"
        }
      },
      "additionalProperties": false
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "description": "Image pull secrets"
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the name of the chart"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full name of the chart"
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Specifies whether a service account should be created"
        },
        "automount": {
          "type": "boolean",
          "description": "Automatically mount a ServiceAccount's API credentials"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the service account"
        },
        "name": {
          "type": "string",
          "description": "The name of the service account to use"
        }
      },
      "additionalProperties": false
    },
    "podAnnotations": {
      "type": "object",
      "description": "Annotations to add to the pod"
    },
    "podLabels": {
      "type": "object",
      "description": "Labels to add to the pod"
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "fsGroup": {
          "type": "integer",
          "description": "Group ID for the pod's volumes"
        }
      },
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "description": "Security context for the container",
      "additionalProperties": true
    },
    "hostNetwork": {
      "type": "boolean",
      "description": "Enable host networking for Govee device discovery"
    },
    "dnsPolicy": {
      "type": "string",
      "description": "DNS policy for the pod",
      "enum": ["Default", "ClusterFirst", "ClusterFirstWithHostNet", "None"]
    },
    "resources": {
      "type": "object",
      "description": "Resource limits and requests for the container",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "govee": {
      "type": "object",
      "description": "Govee API credentials and configuration",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Name of an existing secret containing Govee credentials"
        },
        "existingSecretKeys": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "description": "Key in the existing secret for the Govee email"
            },
            "password": {
              "type": "string",
              "description": "Key in the existing secret for the Govee password"
            },
            "apiKey": {
              "type": "string",
              "description": "Key in the existing secret for the Govee API key"
            }
          },
          "additionalProperties": false
        },
        "email": {
          "type": "string",
          "description": "Govee account email (only used if existingSecret is not set)"
        },
        "password": {
          "type": "string",
          "description": "Govee account password (only used if existingSecret is not set)"
        },
        "apiKey": {
          "type": "string",
          "description": "Govee API key (only used if existingSecret is not set)"
        },
        "temperatureScale": {
          "type": "string",
          "enum": ["C", "F"],
          "description": "Temperature scale: C for Celsius or F for Fahrenheit"
        }
      },
      "additionalProperties": false
    },
    "mqtt": {
      "type": "object",
      "description": "MQTT broker configuration",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Name of an existing secret containing MQTT credentials"
        },
        "existingSecretKeys": {
          "type": "object",
          "properties": {
            "user": {
              "type": "string",
              "description": "Key in the existing secret for the MQTT username"
            },
            "password": {
              "type": "string",
              "description": "Key in the existing secret for the MQTT password"
            }
          },
          "additionalProperties": false
        },
        "host": {
          "type": "string",
          "description": "MQTT broker hostname"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "MQTT broker port"
        },
        "user": {
          "type": "string",
          "description": "MQTT username (only used if existingSecret is not set)"
        },
        "password": {
          "type": "string",
          "description": "MQTT password (only used if existingSecret is not set)"
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "style": {
          "type": "string",
          "enum": ["always", "never", "auto"],
          "description": "Enable colored output"
        },
        "level": {
          "type": "string",
          "description": "Log level (e.g., govee=info, govee=debug, govee=trace)"
        }
      },
      "additionalProperties": false
    },
    "timezone": {
      "type": "string",
      "description": "Timezone for log timestamps (e.g., America/New_York, UTC)"
    },
    "extraEnv": {
      "type": "array",
      "description": "Additional environment variables",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "required": ["name"]
      }
    },
    "extraEnvFrom": {
      "type": "array",
      "description": "Environment variables from secrets or configmaps",
      "items": {
        "type": "object"
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistence configuration for application data",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable persistence"
        },
        "storageClass": {
          "type": "string",
          "description": "Storage class for the PVC"
        },
        "accessMode": {
          "type": "string",
          "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"],
          "description": "Access mode for the PVC"
        },
        "size": {
          "type": "string",
          "description": "Size of the PVC"
        },
        "existingClaim": {
          "type": "string",
          "description": "Name of an existing PVC to use"
        },
        "mountPath": {
          "type": "string",
          "description": "Mount path for the volume"
        }
      },
      "additionalProperties": false
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node labels for pod assignment"
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod assignment",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod assignment"
    }
  },
  "additionalProperties": false
}
