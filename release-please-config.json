{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "helm",
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "include-v-in-tag": false,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "chore", "section": "Miscellaneous" },
    { "type": "deps", "section": "Dependencies" }
  ],
  "packages": {
    "charts/13ft": {
      "component": "13ft",
      "paths": ["charts/13ft"]
    },
    "charts/esphome": {
      "component": "esphome",
      "paths": ["charts/esphome"]
    },
    "charts/govee2mqtt": {
      "component": "govee2mqtt",
      "paths": ["charts/govee2mqtt"]
    },
    "charts/it-tools": {
      "component": "it-tools",
      "paths": ["charts/it-tools"]
    },
    "charts/manyfold": {
      "component": "manyfold",
      "paths": ["charts/manyfold"]
    },
    "charts/newt": {
      "component": "newt",
      "paths": ["charts/newt"]
    },
    "charts/traccar": {
      "component": "traccar",
      "paths": ["charts/traccar"]
    }
  }
}
